# OpenRouter LLM narratives — all optional.
# The system runs fully offline without any of these (template narratives are always present).

# --- Required to enable real LLM calls ---
# OPENROUTER_API_KEY=sk-or-v1-...

# --- Model selection (default: nvidia/nemotron-nano-9b-v2:free) ---
# OPENROUTER_MODEL=nvidia/nemotron-nano-9b-v2:free

# --- Dry-run mode: exercises the full LLM code path with a mock payload (no HTTP, no billing) ---
# OPENROUTER_DRY_RUN=1

# --- Top-N: how many CRITICAL alerts to pre-generate narratives for during pipeline run (default 12) ---
# OPENROUTER_LLM_TOPN=12

# --- Optional ranking headers sent to OpenRouter ---
# OPENROUTER_REFERER=https://your-site.example.com
# OPENROUTER_TITLE=PS4 Insider Threat Sentinel

# Cost estimate: nvidia/nemotron-nano-9b-v2:free — no cost on free tier
